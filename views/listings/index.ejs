<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Listing of properities</title>
  </head>
  <body>
    <h1>Listings</h1>

    <ul>
      <% listings.forEach((item) => { %>
      <a href="/listing/<%= item._id %>"><li>
        Address: <%= item.adress %>
        City: <%= item.city %>
        size: <%= item.size %>
        Price: <%= item.price %>

        
          <!-- add a page to visit owner page??? -->
          owned by: <%= item.owner.username %>
        

          <span>Published on <%= item.createdAt.toLocaleString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: true }).toLowerCase()%></span>
        <img src="<%= item.image.url %>" alt="cool image of the properity" width="100%"> 
      </li></a>
      <% }) %>
    </ul>
  </body>
</html>
